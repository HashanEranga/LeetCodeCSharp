{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug xUnit Tests",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build-tests",
      "program": "dotnet",
      "args": [
        "test",
        "${workspaceFolder}/LeetCodeCSharp.Tests/LeetCodeCSharp.Tests.csproj",
        "--no-build",
        "--logger",
        "console;verbosity=detailed"
      ],
      "cwd": "${workspaceFolder}",
      "stopAtEntry": false,
      "console": "integratedTerminal"
    }
  ]
}
